# Auth0（Vercel の Auth0 連携や Auth0 Dashboard の Regular Web Application）
# https://github.com/auth0/nextjs-auth0#Getting-Started
AUTH0_DOMAIN=dev-wtesv6441wlwi2pz.us.auth0.com
AUTH0_CLIENT_ID=XVbL7iaV7RX81RXDprrrVvjL0of2nuTy
AUTH0_CLIENT_SECRET=JB4-YrmxMFAscZ-ZAzmN0NU8-qSyhInAMh5f1t3R8WcH8gZts-EFsje76pUBT5MR
AUTH0_SECRET=6d684a02a52a022b6bf2004b9b1a3b2dea1654930c28012df784f67213446d5a
# ローカル: http://localhost:3000 ／ 本番: デプロイ URL。未設定時はリクエストから推定（Preview 向け）
APP_BASE_URL=

# Supabase（Vercel の Storage で Supabase を接続すると自動注入される値と同じ名前）
# ローカル develop: .env.local にコピーして Supabase ダッシュボードの値を入れてください。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 本番のサーバー側一覧取得用（Dashboard → Project Settings → API の service_role）。NEXT_PUBLIC にしないこと。
SUPABASE_SERVICE_ROLE_KEY=

# Neon（Vercel Storage の Neon 連携や Neon Console の接続文字列）
# ※これを入れていると、Postgres 向けスクリプトは Neon に繋がります。Supabase の Table Editor とは別 DB です。
DATABASE_URL=

# Supabase の Postgres に直接繋ぐとき（Dashboard → Project Settings → Database → URI）
# npm run migrate:supabase-user-tables で user-table / user-report を作成する際に使用。Neon の DATABASE_URL とは別に置く。
SUPABASE_DATABASE_URL=

# ベーシック認証（両方セットされたときのみ有効。本番では Vercel の Environment Variables に登録）

# microCMS（ブログ API）サービス ID は「xxx」部分のみ（https://xxx.microcms.io の xxx）。API キーは microCMS 管理画面の API キー。
MICROCMS_SERVICE_DOMAIN=d4s2z43rur
MICROCMS_API_KEY=yEpj0tqz2MrH06Wmmv7fJuku71MWcP7MwLIj
# コンテンツ API のエンドポイント名（管理画面の API 名。省略時は blog）
# MICROCMS_API_ENDPOINT=blog
